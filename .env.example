# Microsoft Azure App Registration
# Register at https://portal.azure.com > Azure Active Directory > App registrations
AZURE_CLIENT_ID=your-azure-client-id
AZURE_TENANT_ID=your-azure-tenant-id  # or "common" for multi-tenant

# Anthropic (Claude) — get key at https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key

# Semantic Scholar (optional — free tier works without key, key raises rate limits)
# Register at https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=

# App settings
# How many days back to pull OneNote pages
LOOKBACK_DAYS=10
# How many candidate papers to fetch per topic before ranking
PAPERS_PER_TOPIC=10
# How many final papers to surface
TOP_N_PAPERS=3
